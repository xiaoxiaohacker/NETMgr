# 数据库配置
DATABASE_URL=mysql+pymysql://netmgr:netmgrpassword@localhost:3306/netmgr

# Redis配置（可选，用于异步任务）
REDIS_URL=redis://localhost:6379/0

# JWT密钥（至少32位长的随机字符串）
SECRET_KEY=your-super-secret-key-here-make-it-long-and-random-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 端口配置
PORT=8000

# CORS配置（多个域名用逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=X-Requested-With,content-type,Authorization,X-Client-Type

# 开发环境标识
ENVIRONMENT=development

# 工作进程数（生产环境建议设为CPU核心数）
WORKERS=1

# 设备状态检查间隔（秒）
DEVICE_STATUS_CHECK_INTERVAL=300

# SNMP配置
DEFAULT_SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=10
SNMP_RETRIES=1

# 任务调度配置
TASK_SCHEDULER_INTERVAL=10

# 日志配置
LOG_LEVEL=INFO
LOG_FILE_SIZE=10MB
LOG_BACKUP_COUNT=5